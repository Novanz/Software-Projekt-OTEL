#!/usr/bin/env bash
set -euo pipefail

STATUS_FILE=/run/podman-prepull.status
STATE_FILE=/run/podman-prepull.state
LOG_TAG="podman-prepull"

images=(
    "ghcr.io/mlflow/mlflow:v3.11.1-full"
    "docker.io/chromadb/chroma:1.5.8"
    "docker.io/ollama/ollama:0.24.0"
)

total=${#images[@]}
i=0
current_image=""

timestamp() {
    date --iso-8601=seconds
}

write_status() {
    local state="$1"
    local message="$2"

    printf '%s\n' "$state" >"$STATE_FILE"
    cat >"$STATUS_FILE" <<EOF
FCOS initial container pre-pull
State: $state
Time: $(timestamp)
Message: $message
EOF
}

append_detail() {
    local message="$1"
    printf '[%s] %s\n' "$(timestamp)" "$message"
}

on_error() {
    local exit_code=$?
    write_status "FAILED" "Pull failed while processing: ${current_image:-unknown image}"
    /usr/bin/logger -t "$LOG_TAG" "FAILED while processing: ${current_image:-unknown image}"
    exit "$exit_code"
}

trap on_error ERR

write_status "RUNNING" "Starting initial image pre-pull (0/$total complete)"
/usr/bin/logger -t "$LOG_TAG" "Starting initial image pre-pull ($total images)"

for img in "${images[@]}"; do
    i=$((i + 1))
    current_image="$img"

    write_status "RUNNING" "[$i/$total] Currently pulling $img"
    append_detail "[$i/$total] pulling $img"
    /usr/bin/logger -t "$LOG_TAG" "[$i/$total] pulling $img"

    /usr/bin/podman pull "$img"

    write_status "RUNNING" "[$i/$total] Finished pulling $img"
    append_detail "[$i/$total] finished $img"
    /usr/bin/logger -t "$LOG_TAG" "[$i/$total] finished $img"
done

write_status "DONE" "Initial image pre-pull completed successfully ($total/$total complete)"
/usr/bin/logger -t "$LOG_TAG" "Initial image pre-pull completed successfully"
