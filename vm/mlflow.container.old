[Unit]
Description=MLflow server
After=network-online.target
Wants=network-online.target

[Container]
ContainerName=mlflow
Image=ghcr.io/mlflow/mlflow:v3.11.1-full
Volume=/var/lib/mlflow:/mlflow:Z
PublishPort=192.168.56.10:9005:5000

Environment=MLFLOW_BACKEND_STORE_URI=sqlite:////mlflow/mlflow.db
Environment=MLFLOW_DEFAULT_ARTIFACT_ROOT=file:///mlflow/artifacts

Exec=mlflow server \
  --host 0.0.0.0 \
  --port 5000 \
  --backend-store-uri sqlite:////mlflow/mlflow.db \
  --default-artifact-root file:///mlflow/artifacts \
  --allowed-hosts 192.168.56.103,192.168.56.103:5000,localhost,localhost:5000,127.0.0.1,127.0.0.1:5000 \
  --cors-allowed-origins http://192.168.56.103:5000,http://localhost:5000,http://127.0.0.1:5000

[Service]
Restart=always
RestartSec=5
TimeoutStartSec=300

[Install]
WantedBy=multi-user.target
