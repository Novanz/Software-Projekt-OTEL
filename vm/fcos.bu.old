variant: fcos
version: 1.6.0

passwd:
  users:
    - name: core
      ssh_authorized_keys:
        - "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAINPgoBJwyBSysQ9HG88Uu9IBOOEhfPKgQLldKzaO2kUf local_vm"

storage:
  files:
    - path: /etc/NetworkManager/system-connections/enp0s8.nmconnection
      mode: 0600
      overwrite: true
      contents:
        inline: |
          [connection]
          id=hostonly
          type=ethernet
          interface-name=enp0s8

          [ipv4]
          method=manual
          addresses=192.168.56.10/24
          dns=192.168.56.1

          [ipv6]
          method=ignore
